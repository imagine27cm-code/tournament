{
  "build": {
    "env": {
      "TURBO_FORCE_CLEAN": "1"
    }
  },
  "buildCommand": "npx prisma generate && npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "functions": {
    "app/api/**/*": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/socket.io/:path*",
      "destination": "/api/socket"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}